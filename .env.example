# Plantilla de variables para --dart-define-from-file (ver lib/core/config/env.dart).
# Copia este archivo a .env.dev / .env.prod y llena los valores reales.
# NUNCA subas .env.dev ni .env.prod al repo — .gitignore ya los excluye.

# dev | staging | prod
ENVIRONMENT=dev

# Supabase (Project Settings > API)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Google Cloud Console > Credentials > OAuth client "Web application"
# (Supabase lo usa para validar el idToken del login nativo de Android)
GOOGLE_SERVER_CLIENT_ID=

# PowerSync Dashboard > instancia > botón "Connect"
POWERSYNC_URL=

# Sentry (opcional — vacío desactiva el reporte de crashes)
SENTRY_DSN=
